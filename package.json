{
  "name": "lab-report",
  "version": "0.1.0",
  "private": true,
  "description": "Kanpur Laboratory desktop application",
  "author": "Kanpur Laboratory Team",
  "homepage": ".",
  "main": "electron/main.js",
  "dependencies": {
    "@react-pdf/renderer": "^3.1.3",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "mongoose": "^9.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "uuid": "^8.3.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "server": "npm run dev --prefix server",
    "server:start": "npm start --prefix server",
    "server:install": "npm install --prefix server",
    "build": "react-scripts build",
    "electron:build": "npm run build && electron-builder --win --x64 --publish never",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src server/src --ext .js,.jsx",
    "lint:fix": "eslint src server/src --ext .js,.jsx --fix",
    "format": "prettier --write src/**/*.{js,jsx} server/src/**/*.js"
  },
  "build": {
    "appId": "com.kanpur.kanpur_lab",
    "productName": "Kanpur Laboratory",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server/",
        "to": "server",
        "filter": ["**/*", "!node_modules/**"]
      }
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5"
  }
}
